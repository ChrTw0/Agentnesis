# ===========================
# API KEYS
# ===========================
# OpenAI directo
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter (para usar Claude, Gemini, Llama, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here
YOUR_SITE_URL=https://yoursite.com  # Optional - para rankings en openrouter.ai
YOUR_SITE_NAME=YourAppName  # Optional - para rankings en openrouter.ai

# ===========================
# LLM CONFIGURATION
# ===========================
# Default model (fallback si no se especifica por agente)
OPENAI_MODEL=gpt-4-turbo-preview

# Temperature settings (global defaults)
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=16000

# ===========================
# MODELS PER AGENT
# ===========================
# Cada agente puede usar un modelo diferente
# OpenAI: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
# OpenRouter: anthropic/claude-3.5-sonnet, google/gemini-pro, meta-llama/llama-3-70b-instruct

# Genesis (Meta-cognición) - Modelo potente para análisis de dominio
GENESIS_MODEL=gpt-4-turbo-preview

# Moderator (Orquestación) - Modelo balanceado para decisiones
MODERATOR_MODEL=gpt-4-turbo-preview

# Integrator (Validación) - Modelo preciso para validar propuestas
INTEGRATOR_MODEL=gpt-4-turbo-preview

# Synthesizer (Síntesis final) - Modelo creativo para consolidar respuesta
SYNTHESIZER_MODEL=anthropic/claude-3.5-sonnet

# Universal Worker (Default para agentes spawneados) - Puede ser más económico
WORKER_MODEL=gpt-3.5-turbo

# Fractal Agent - Modelos por fase del bucle cognitivo
FRACTAL_PLANNER_MODEL=gpt-4-turbo-preview    # Planeación requiere razonamiento
FRACTAL_EXECUTOR_MODEL=gpt-3.5-turbo         # Ejecución puede ser más económica
FRACTAL_CRITIC_MODEL=gpt-4-turbo-preview     # Crítica requiere precisión

# ===========================
# DEVELOPER MODE
# ===========================
DEVELOPER_MODE=false  # Enable logging of all LLM interactions
LOG_DIR=./logs  # Directory to save logs (creates if not exists)
LOG_LLM_RESPONSES=true  # Log LLM prompts and responses
LOG_GRAPH_STATES=true  # Log graph state transitions
LOG_FORMAT=json  # Format: json or txt

# ===========================
# GENESIS CONFIGURATION
# ===========================
GENESIS_MAX_AGENTS=10
GENESIS_MAX_SPAWN_DEPTH=  # Leave empty for None (Genesis decides)
GENESIS_ALLOW_DYNAMIC_SPAWN=true
GENESIS_SPAWN_COOLDOWN=0
GENESIS_ENABLE_AGENT_REUSE=true
GENESIS_SATURATION_THRESHOLD=0.8

# ===========================
# MODERATOR CONFIGURATION
# ===========================
MODERATOR_MAX_ITERATIONS=20
MODERATOR_REJECTION_LOOP_THRESHOLD=3
MODERATOR_ENABLE_HUMAN_OVERRIDE=true

# ===========================
# INTEGRATOR CONFIGURATION
# ===========================
INTEGRATOR_STRICT_MODE=false
INTEGRATOR_ALLOW_PROPERTY_OVERRIDE=true
INTEGRATOR_MAX_CONFLICTS_PER_PROPOSAL=5

# ===========================
# UNIVERSAL WORKER CONFIGURATION
# ===========================
WORKER_EXECUTION_TIMEOUT=120
WORKER_MAX_RETRIES_ON_ERROR=1
WORKER_CACHE_SUBGRAPHS=true

# ===========================
# FRACTAL AGENT CONFIGURATION
# ===========================
FRACTAL_MAX_RETRIES=3
FRACTAL_ABSOLUTE_MAX_RETRIES=5

# ===========================
# CONTEXT RETRIEVAL (RAG)
# ===========================
CONTEXT_TOP_K=10
CONTEXT_USE_EMBEDDINGS=false
CONTEXT_MIN_RELEVANCE_SCORE=0.5
CONTEXT_INCLUDE_RELATIONS=true

# ===========================
# SYNTHESIZER CONFIGURATION
# ===========================
SYNTHESIZER_OUTPUT_FORMAT=prose  # Options: prose, structured, markdown
SYNTHESIZER_INCLUDE_KG_DUMP=false
SYNTHESIZER_VERBOSITY=normal  # Options: concise, normal, detailed

# ===========================
# GRAPH CONFIGURATION
# ===========================
GRAPH_CHECKPOINT_ENABLED=true
GRAPH_CHECKPOINT_DIR=./checkpoints
GRAPH_RECURSION_LIMIT=75

# ===========================
# TOOLS CONFIGURATION
# ===========================
# Habilitar herramientas externas (búsqueda web, scraping)
# Requiere SearXNG corriendo localmente antes de activar
TOOLS_ENABLED=false
SEARXNG_URL=http://localhost:8080
